[Unit]
Description=Gunicorn instance to serve resis
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/resis
Environment="PATH=/var/www/resis/venv/bin"
ExecStart=/var/www/resis/venv/bin/gunicorn --workers 4 --bind unix:/run/resis.sock app:create_app()

[Install]
WantedBy=multi-user.target
