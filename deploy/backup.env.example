## Example environment file for backup_postgres.service
# Copy to /etc/resis/backup.env and secure permissions (chmod 600)

# Backup mode: 'docker' (exec into db container) or 'local'
BACKUP_MODE=docker

# Where backups are stored on the host
BACKUP_DIR=/var/backups/resis

# Database credentials used by pg_dump when run locally or inside the container
PGUSER=resis
PGPASSWORD=resispass
PGDATABASE=resis

# Retention in days (files older than this will be deleted). Set to 0 to disable.
RETENTION_DAYS=14

# Optional encryption: set to 'true' to encrypt backups with GPG symmetric cipher.
# If enabled, set GPG_PASSPHRASE below (keep this secret!).
ENCRYPT_BACKUPS=false
GPG_PASSPHRASE=
