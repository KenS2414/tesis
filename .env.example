# Example environment variables for local development
# Copy this file to `.env` and fill values (do NOT commit `.env`).

# A secret key used by Flask for session signing
SECRET_KEY=

# Optional: local sqlite database URL (defaults to sqlite:///app.db)
#DATABASE_URL=

# Optional S3 settings for uploads (used in tests when configured)
#S3_BUCKET=
#S3_REGION=
#S3_ENDPOINT=

# Optional: Sentry DSN for error reporting (do NOT commit real DSNs)
# Obtain a DSN by creating a project in Sentry (https://sentry.io/) and copy the
# "Client Keys (DSN)" value into `.env` as shown below. Example placeholder:
# SENTRY_DSN=https://public_key@o0.ingest.sentry.io/1234567
# Note: the example above is a placeholder — replace with your project's DSN.

# Optional: enable logging to rotating file (set LOG_TO_FILE=true)
# LOG_TO_FILE=false
# LOG_FILE=logs/app.log
# Copy this file to .env and edit values for development
SECRET_KEY=change-me-to-a-secret
ADMIN_PASSWORD=adminpass123
